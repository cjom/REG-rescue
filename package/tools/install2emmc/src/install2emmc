BOOTPART=$(grep -m 1 /boot /proc/mounts | sed 's| /boot .*||')
BOOTDISK="${BOOTPART%p[0-9]*}"
EMMCDISK=""
TMP=/tmp/mnt

for TYPE in /sys/class/block/mmcblk*/device/type; do
    if grep -q "MMC" "${TYPE}"; then
        EMMCDISK="/dev/$(echo "${TYPE}" | awk -F/ '{print $5}')"
        break
    fi
done

if [ -z "${EMMCDISK}" ]; then
    echo "Can't find eMMC module!"
    exit 1
fi

if [ "${BOOTDISK}" = "${EMMCDISK}" ]; then
    echo "Your device has booted from the eMMC module!"
    exit 1
fi

if [ ! -b "${EMMCDISK}" ]; then
    echo "Error: eMMC not found."
    echo "It was supposed to be in ${EMMCDISK} but that path doesn't exist."
    exit 1
fi

echo ""
echo "==============================="
echo "Installing REG-Linux to eMMC"
echo "==============================="
echo ""
echo "eMMC found at ${EMMCDISK}"
echo ""
echo -n "WARNING: ALL DATA ON eMMC WILL BE ERASED! Continue (y/N)?  "
read -rn 1 ANSWER

if [ ! "${ANSWER}" = "y" ]; then
    echo ""
    echo "Aborting..."
    exit 0
fi
echo ""

umount "${EMMCDISK}"* > /dev/null 2>&1

echo "Erasing eMMC ..."
dd if=/dev/zero of="${EMMCDISK}" bs=1M count=1 conv=fsync > /dev/null 2>&1

echo "Creating partitions"
SYSTEM_SIZE=$(blockdev --getsize64 "${BOOTPART}")
# Round up to MiB boundary, add 1 MiB for the initial alignment offset
SYSTEM_MIB=$(( (SYSTEM_SIZE + 1048575) / 1048576 + 1 ))
parted -s "${EMMCDISK}" mklabel msdos
parted -s "${EMMCDISK}" -a optimal mkpart primary fat32 1MiB "${SYSTEM_MIB}MiB"
parted -s "${EMMCDISK}" set 1 boot on
parted -s "${EMMCDISK}" -a optimal mkpart primary ext4 "${SYSTEM_MIB}MiB" 100%
sync
partprobe "${EMMCDISK}"

echo "Creating filesystems"
dd if=/dev/zero of="${EMMCDISK}p1" bs=1M count=1 conv=fsync > /dev/null 2>&1
mkfs.vfat -n REGLINUX "${EMMCDISK}p1" > /dev/null 2>&1
dd if=/dev/zero of="${EMMCDISK}p2" bs=1M count=1 conv=fsync > /dev/null 2>&1
mkfs.ext4 -L SHARE "${EMMCDISK}p2" > /dev/null 2>&1
sync

echo "Installing bootloader"
dd if="${BOOTDISK}" skip=8 of="${EMMCDISK}" bs=1k seek=8 count=768 conv=fsync > /dev/null 2>&1

echo "Copying system files"
mkdir -p ${TMP}
mount -t vfat "${EMMCDISK}p1" ${TMP} || { echo "Failed to mount eMMC boot partition!"; exit 1; }
cp -vR /boot/* ${TMP}/
sync

echo "Adjusting partition UUIDs"
NEWUUID=$(blkid -c /dev/null -o value -s UUID "${EMMCDISK}p1")
if [ -n "$NEWUUID" ]; then
    if [ -f /boot/boot.scr ]; then
        dumpimage -T script -p 0 -o /tmp/boot.cmd.tmp /boot/boot.scr
        OFFSET=$(grep -abo -m1 '^#' /tmp/boot.cmd.tmp | cut -d: -f1)
        if [ -n "$OFFSET" ]; then
            dd if="/tmp/boot.cmd.tmp" of="/tmp/boot.cmd" bs=1 skip="$OFFSET" 2>/dev/null
        else
            echo "Error extracting boot.cmd from boot.scr"
            display_error
        fi
        sed -i "s/label=REGLINUX/root=UUID=${NEWUUID}/g;s/root=UUID=[a-fA-F0-9-]*/root=UUID=${NEWUUID}/g" {} /tmp/boot.cmd
        mkimage -C none -A arm64 -T script -d /tmp/boot.cmd ${TMP}/boot.scr
    fi
    find "${TMP}/" -type f \( -iname "LinuxLoader.cfg" -o -iname "extlinux.conf" -o -iname "cmdline.txt" -o -iname "boot.cmd" -o -iname "boot.ini" -o -iname "uEnv.txt" -o -iname "syslinux.cfg" -o -iname "grub.cfg" \) -exec sed -i "s/label=REGLINUX/root=UUID=${NEWUUID}/g;s/root=UUID=[a-fA-F0-9-]*/root=UUID=${NEWUUID}/g" {} \+
    echo "Updated UUID to ${NEWUUID}"
else
    echo "Error getting UUID of eMMC boot partition"
    display_error
fi

umount ${TMP}
echo "Done. Power off the device, remove the SD card and boot from eMMC."
